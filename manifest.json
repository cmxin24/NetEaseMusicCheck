{
  "manifest_version": 3,
  "name": "NetEaseMusicActivator",
  "version": "1.0.0",
  "icons": {
    "16": "images/red16.png",
    "48": "images/red48.png",
    "128": "images/red128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/red16.png",
      "48": "images/red48.png",
      "128": "images/red128.png"
    },
    "default_title": "NetEaseMusicActivator: Active"
  },
  "description": "NetEase Cloud Music automatic check-in assistant.",
  "permissions": [
    "storage",
    "alarms",
    "cookies"
  ],
  "host_permissions": [
    "*://*.music.163.com/*",
    "*://music.163.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}